# Copy this file to .env and fill in your values.
# Never commit .env to version control.

PORT=8080

# Supabase connection string (Project Settings -> Database -> Connection string URI)
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# Supabase JWT Secret for validating authentication tokens
# Get this from: Project Settings -> API -> JWT Secret
# IMPORTANT: Leave empty for development mode (disables auth, uses DefaultUserID=1)
# Set this value in production to enable JWT authentication
SUPABASE_JWT_SECRET=

# Comma-separated origins for CORS (e.g. your frontend dev server)
ALLOWED_ORIGINS=http://localhost:5173
